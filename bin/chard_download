#!/bin/bash
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
CYAN=$'\033[36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

if grep -q '^PRETTY_NAME="Debian' /etc/os-release && [ -d /opt/google/cros-containers ]; then
	echo ""
    echo "${RED}${BOLD}Chard cannot be installed inside Crostini. Please use Crosh instead! ${RESET}"
	echo "${YELLOW}To install Chard, please enable Developer mode, and install it via crosh (ctrl-alt-t) in ChromeOS. ${RESET}"
	sleep 5
    exit 0
fi

echo
echo "${GREEN}"
echo "╔═══════════════════════════════════════════════════════════════════════════════════════════╗"
echo "║${BOLD}                                   Select Chard Distro:${RESET}${GREEN}                                    ║"
echo "╚═══════════════════════════════════════════════════════════════════════════════════════════╝"
echo "${CYAN}╔════════════════════════════════════════════╗${RESET}${MAGENTA} ╔════════════════════════════════════════════╗${RESET}"
echo "${CYAN}║                                            ║${RESET}${MAGENTA} ║                                            ║${RESET}"
echo "${CYAN}║${BOLD}   Option 1 - Chard Arch:${RESET}${CYAN}                   ║${RESET}${MAGENTA} ║${BOLD}   Option 2 - Chard Gentoo:${RESET}${MAGENTA}                 ║${RESET}"           
echo "${CYAN}║                                            ║${RESET}${MAGENTA} ║                                            ║${RESET}"           
echo "${CYAN}║ - Installs 10x faster than Chard Gentoo.   ║${RESET}${MAGENTA} ║ - Export Sommelier directly to ChromeOS.   ║${RESET}"          
echo "${CYAN}║ - Supports Steam, Heroic, and most games.  ║${RESET}${MAGENTA} ║ - Recommended for ChromeOS developing.     ║${RESET}"           
echo "${CYAN}║ - Multilib support for x86_64.             ║${RESET}${MAGENTA} ║ - Optimized builds for architecture.       ║${RESET}"
echo "${CYAN}║                                            ║${RESET}${MAGENTA} ║                                            ║${RESET}"
echo "${CYAN}╚════════════════════════════════════════════╝${RESET}${MAGENTA} ╚════════════════════════════════════════════╝${RESET}"
echo "${RED}╔═══════════════════════════════════════════════════════════════════════════════════════════╗"
echo "║${BOLD}                                     Option 3 - Exit${RESET}${RED}                                       ║"
echo "╚═══════════════════════════════════════════════════════════════════════════════════════════╝"
echo "${RESET}${BLUE}${BOLD}"

read -rp "                                    Enter Option [1-3]: " choice

case "$choice" in
    1)
        URL="https://raw.githubusercontent.com/shadowed1/Chard/main/Arch/Chard_Installer.sh"
        ;;
    2)
        URL="https://raw.githubusercontent.com/shadowed1/Chard/main/Gentoo/Chard_Installer.sh"
        ;;
    3)
        echo "Exiting."
        exit 0
        ;;
    *)
        echo "Invalid choice."
        exit 1
        ;;
esac

if find /home/chronos/user -maxdepth 1 -type d -name MyFiles >/dev/null 2>&1; then
    DOWNLOAD_DIR="/home/chronos/user"
    DISPLAY_PATH="/home/chronos/user/Chard_Installer"
else
    DOWNLOAD_DIR="$HOME"
    DISPLAY_PATH="~/Chard_Installer"
fi

echo "${RESET}${BLUE}" 
echo "                           Downloading to: ${BOLD}$DISPLAY_PATH"
echo "${RESET}" 

curl -L "$URL" -o "$DOWNLOAD_DIR/Chard_Installer" || {
    echo "${RED}Download failed. ${RESET}"
    exit 1
}

echo "          ${RED}For ChromeOS users - CTRL-ALT-BACK exits VT-2 and CTRL-ALT-REFRESH enters VT-2! ${RESET}"
echo "   ${YELLOW}Run the commands below with ${RESET}${CYAN}${BOLD}sudo in crosh (not enabled by default)${RESET}${YELLOW} or ${RESET}${MAGENTA}VT-2 logged in as ${BOLD}chronos${RESET}${YELLOW}:${RESET}"
echo "               ${BLUE}CTRL-ALT-REFRESH enters VT-2.${RESET} ${CYAN}CTRL-ALT-BACK returns to ChromeoS.${RESET}"
echo
echo

RUN_USER="${CHARD_USER:-$USER}"

if find /home/chronos/user -maxdepth 1 -type d -name MyFiles >/dev/null 2>&1; then
    echo
    echo "${GREEN}${BOLD}ChromeOS install${RESET}"
    echo
    echo "${YELLOW}If using crew-sudo, please uninstall it and use Sudocrosh instead.${RESET}"
    echo "${CYAN}Run these commands in VT-2 logged in as chronos (or in crosh with sudo enabled):${RESET}"
    echo "${BLUE}${BOLD}"
    echo "cd"
    echo "sudo mv Chard_Installer /usr/local"
    echo "sudo bash /usr/local/Chard_Installer"
    echo "${RESET}"
else
    echo
    echo "${GREEN}${BOLD}Linux install${RESET}"
    echo
    echo "${CYAN}Running:${RESET}"
    echo "${BLUE}${BOLD}sudo -u $RUN_USER bash ~/Chard_Installer ${RESET}"
    sleep 3
    sudo -u "$RUN_USER" bash ~/Chard_Installer
fi
