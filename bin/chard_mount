#!/bin/bash
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
CYAN=$'\033[36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

if ls /.chardrc > /dev/null 2>&1; then
    echo "${RED}chard_mount must be run from the host shell, not inside Chard.${RESET}"
    sleep 3
    exit 1
fi

source /home/chronos/user/.bashrc 2>/dev/null
source $CHARD_ROOT/.chard.preload 2>/dev/null
STATE_FILE="$CHARD_ROOT/tmp/usb_mount_state"
MOUNT_POINT="$CHARD_ROOT/$CHARD_HOME/external"
: > "$STATE_FILE"
USB_DEVICES=$(lsblk -dpno NAME,TRAN | awk '$2=="usb"{print $1}')
if ls /dev/nvme* >/dev/null 2>&1 && [ -b /dev/mmcblk0 ]; then
    USB_DEVICES="$USB_DEVICES /dev/mmcblk0"
fi
if [ -z "$USB_DEVICES" ]; then
    echo
    echo "${YELLOW}No External drives detected.${RESET}"
    exit 0
fi
echo
echo "${GREEN}Detected External drives: ${BOLD}"
echo "$USB_DEVICES"
echo "${RESET}"
for DEV in $USB_DEVICES; do
    lsblk -lnpo NAME,MOUNTPOINT "$DEV" | awk '$2 != ""' >> "$STATE_FILE"
done
echo "${RESET}${BLUE}Mounted to $CHARD_ROOT/$CHARD_HOME/external: ${BOLD}"
cat "$STATE_FILE"
echo "${RESET}"
sudo mkdir -p "$MOUNT_POINT"
while read -r PART MP; do
    BASENAME=$(basename "$PART")
    TARGET="$MOUNT_POINT/$BASENAME"
    sudo mkdir -p "$TARGET"
    if sudo env LD_PRELOAD="$LD_PRELOAD" "$CHARD_ROOT/usr/bin/bindfs" -o uid=1000,gid=1001 --perms=ugo+x "$MP" "$TARGET" 2>/dev/null; then
        echo "${GREEN}bindfs mounted:${BOLD} $MP to $TARGET${RESET}"
    else
        echo "${YELLOW}bindfs failed, falling back to bind mount:${BOLD} $MP to $TARGET${RESET}"
        sudo mount --bind "$MP" "$TARGET" 2>/dev/null
    fi
done < "$STATE_FILE"
unset LD_PRELOAD
