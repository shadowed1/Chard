#!/bin/bash
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
MAGENTA=$(tput setaf 5)
CYAN=$(tput setaf 6)
BOLD=$(tput bold)
RESET=$(tput sgr0)
STATE_FILE="$CHARD_ROOT/tmp/usb_mount_state"
MOUNT_POINT="$CHARD_ROOT/$CHARD_HOME/external"

if ls /.chardrc > /dev/null 2>&1; then
    echo "${RED}chard_unmount must be run from the host shell, not inside Chard.${RESET}"
    sleep 3
    exit 1
fi

if mountpoint -q "$MOUNT_POINT"; then
    sudo umount "$MOUNT_POINT" 2>/dev/null
fi
if [[ -f "$STATE_FILE" ]]; then
    while read -r PART MP; do
        BASENAME=$(basename "$PART")
        TARGET="$MOUNT_POINT/$BASENAME"
        if mountpoint -q "$TARGET" 2>/dev/null; then
            sudo umount "$TARGET" 2>/dev/null
            echo "${CYAN}Unmounted:${RESET} $TARGET"
        fi
        echo ""
        echo "${CYAN}Restoring: ${BOLD}"
        echo "  $PART to '$MP'"
        echo "${RESET}"
        sudo mkdir -p "$MP" 2>/dev/null
        sudo mount "$PART" "$MP" 2>/dev/null
    done < "$STATE_FILE"
    sudo rm -f "$STATE_FILE" 2>/dev/null
fi
if [[ -d "$MOUNT_POINT" ]]; then
    for DIR in "$MOUNT_POINT"/*/; do
        [[ -d "$DIR" ]] || continue
        if ! mountpoint -q "$DIR" 2>/dev/null && [ -z "$(ls -A "$DIR" 2>/dev/null)" ]; then
            sudo rmdir "$DIR"
            echo "${YELLOW}Removed empty dir:${BOLD} $DIR ${RESET}"
        fi
    done
fi
