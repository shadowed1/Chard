# <<< CHARD_ENV <<<

# <<< CHARD_ROOT_MARKER >>>
CHARD_ROOT=""
CHARD_HOME=""
CHARD_USER=""
# <<< END_CHARD_ROOT_MARKER >>>

[ -f "$CHARD_ROOT/.chard.env" ] && source "$CHARD_ROOT/.chard.env"
[ -f "$CHARD_ROOT/.chard.logic" ] && source "$CHARD_ROOT/.chard.logic"

alias cr='chard root'
alias smrt='SMRT'
alias chariot='chard chariot'
CR="$CHARD_ROOT"

# <<< END CHARD_ENV <<<
