# <<< CHARD_ENV <<<

# <<< CHARD_ROOT_MARKER >>>
CHARD_ROOT=""
CHARD_HOME=""
CHARD_USER=""
# <<< END_CHARD_ROOT_MARKER >>>

[ -f "$CHARD_ROOT/.chard.env" ] && source "$CHARD_ROOT/.chard.env"
[ -f "$CHARD_ROOT/.chard.logic" ] && source "$CHARD_ROOT/.chard.logic"

alias safe='$CHARD_ROOT/bin/chard safe'
alias cr='$CHARD_ROOT/bin/chard root'
alias chariot='$CHARD_ROOT/bin/chard chariot'
CR="$CHARD_ROOT"

# <<< END CHARD_ENV <<<
